# Copy this file to `.env` and fill in your values.
# `.env` is git-ignored.

# Google AI Studio API key - get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# JWT signing key - MUST be at least 32 characters. Generate one with:
#   openssl rand -base64 48
# Or use any long random string. KEEP THIS SECRET.
JWT_SIGN_KEY=change-me-to-a-long-random-string-at-least-32-chars-long

# Prod-only (Railway sets these automatically when you add Postgres plugin)
# DATABASE_URL=jdbc:postgresql://host:5432/railway
# DATABASE_USER=postgres
# DATABASE_PASSWORD=...
