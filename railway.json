{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["jdk21", "maven"]
        },
        "build": {
          "cmds": ["cd backend && ./mvnw package -DskipTests -Dquarkus.package.jar.type=uber-jar"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "java -jar backend/target/*-runner.jar",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
